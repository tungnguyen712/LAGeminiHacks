# Copy to `.env` at this repo root (backend loads `../.env` when you run uvicorn from `backend/`).
#
# --- Google Maps (Routes API) ---
# 1. Google Cloud Console → APIs & Services → Enable "Routes API".
# 2. Credentials → Create API key → restrict key (optional): Application restrictions + API restriction = Routes API only.
# 3. Billing must be enabled on the project (Routes API is a paid product with free tier).
#
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
#
# --- Gemini (same key works for scoring, TTS, Live proxy) ---
# 1. https://aistudio.google.com/apikey → Create API key.
# 2. In Google AI Studio / Cloud, ensure the key can call Generative Language API.
#
GEMINI_API_KEY=your_gemini_api_key_here
#
# Model IDs (override if Google renames models)
GEMINI_SCORING_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
