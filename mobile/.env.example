# Copy to `mobile/.env` (never commit real keys).

# Base URL of the PathSense FastAPI server.
# Simulator on same machine: http://localhost:8000
# Android emulator: often http://10.0.2.2:8000
# Physical phone: http://<your-computer-LAN-IP>:8000
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: native Maps SDK on device (separate from server-side Routes API key).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_sdk_key_here
